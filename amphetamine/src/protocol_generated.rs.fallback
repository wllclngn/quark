    fn handle_open_esync(&mut self, _client_fd: i32, _buf: &[u8]) -> crate::event_loop::Reply {
        unimplemented_reply()
    }
    fn handle_get_esync_fd(&mut self, _client_fd: i32, _buf: &[u8]) -> crate::event_loop::Reply {
