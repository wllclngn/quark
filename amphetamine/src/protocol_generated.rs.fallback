    }
}

fn unimplemented_reply() -> crate::event_loop::Reply {
    let hdr = super::ReplyHeader { error: 0xC000_0002, reply_size: 0 };
    let size = std::mem::size_of::<super::ReplyHeader>();
    let mut buf = [0u8; 64];
    unsafe {
        std::ptr::copy_nonoverlapping(
            &hdr as *const _ as *const u8,
            buf.as_mut_ptr(),
            size,
        );
    }
    crate::event_loop::Reply::Fixed { buf, len: size }
}

// ── Dispatch ─────────────────────────────────────────────────────────────

pub fn dispatch_request(
    code: super::RequestCode,
    handler: &mut impl RequestHandler,
    client_fd: i32,
    buf: &[u8],
) -> crate::event_loop::Reply {
    match code {
        super::RequestCode::NewProcess => handler.handle_new_process(client_fd, buf),
        super::RequestCode::GetNewProcessInfo => handler.handle_get_new_process_info(client_fd, buf),
