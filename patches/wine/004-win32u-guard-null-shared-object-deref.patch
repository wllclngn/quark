From: quark <quark@localhost>
Subject: [PATCH] win32u: guard NULL shared object dereference with sentinel

During early thread initialization, shared session object lookups
return NULL when the server returns a zero locator. Downstream
callers dereference this NULL pointer at offset 0x18, crashing
winedevice service threads.

Return a static zeroed sentinel instead of NULL from
find_shared_session_object. All fields read as zero: seqlock
sees seq=0 (even), get_id returns 0, callers treat id=0 as
cache miss and fall back to server round-trip. NULL guards on
seqlock/get_id remain as defense-in-depth.

Signed-off-by: quark <quark@localhost>
---
diff --git a/dlls/win32u/winstation.c b/dlls/win32u/winstation.c
index 6190e45..275cb2f 100644
--- a/dlls/win32u/winstation.c
+++ b/dlls/win32u/winstation.c
@@ -79,20 +79,26 @@ static struct session_thread_data *get_session_thread_data(void)
     return thread_info->session_data;
 }

+/* Sentinel: returned when session lookup fails. All fields zero. */
+static const shared_object_t null_shared_object;
+
 void shared_object_acquire_seqlock( const shared_object_t *object, UINT64 *seq )
 {
+    if (!object) { *seq = 0; return; }
     while ((*seq = ReadNoFence64( &object->seq )) & 1) YieldProcessor();
     __SHARED_READ_FENCE;
 }

 BOOL shared_object_release_seqlock( const shared_object_t *object, UINT64 seq )
 {
+    if (!object) return TRUE;
     __SHARED_READ_FENCE;
     return ReadNoFence64( &object->seq ) == seq;
 }

 static object_id_t shared_object_get_id( const shared_object_t *object )
 {
+    if (!object) return 0;
     struct object_lock lock = OBJECT_LOCK_INIT;
     do
     {
@@ -185,7 +191,7 @@ const shared_object_t *find_shared_session_object( object_id_t id, mem_size_t of
         WARN( "Session object id doesn't match expected id %s\n", wine_dbgstr_longlong(id) );
     }

-    return NULL;
+    return &null_shared_object;
 }

 void shared_session_init(void)
